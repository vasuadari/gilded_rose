#!/usr/bin/env ruby
# frozen_string_literal: true

# This script provides a command-line interface to simulate
# the daily updates of the Gilded Rose inventory.

# Require Bundler to ensure the gem's dependencies are loaded correctly.
require 'bundler/setup'

# Require your Gilded Rose gem. This will load all your refactored classes
# including GildedRose, GildedRose::Item, and the Items namespace.
require 'gilded_rose'

# Define a function to run the simulation
def run_simulation(days_to_simulate = 1)
  # Initialize the Gilded Rose with a predefined set of items.
  # These are standard items from the kata's original requirements.
  items = [
    Item.new("Vest", 10, 20),
    Item.new("Aged Brie", 2, 0),
    Item.new("Elixir of the Mongoose", 5, 7),
    Item.new("Sulfuras, Hand of Ragnaros", 0, 80),
    Item.new("Sulfuras, Hand of Ragnaros", -1, 80),
    Item.new("Backstage passes to a TAFKAL80ETC concert", 15, 20),
    Item.new("Backstage passes to a TAFKAL80ETC concert", 10, 49),
    Item.new("Backstage passes to a TAFKAL80ETC concert", 5, 49),
    # A "Conjured" item
    Item.new("Conjured Mana Cake", 3, 6),
    Item.new("Conjured Aged Brie", 5, 20), # Example of Conjured on a non-degrading item
    Item.new("Conjured Sulfuras, Hand of Ragnaros", 2, 0)
  ]

  # Create an instance of your refactored GildedRose system
  gilded_rose_app = GildedRose.new(items)

  print_lambda = lambda { |item| puts "item: name = #{item.name}, quality = #{item.quality}, sell_in = #{item.sell_in}" } 

  # Print initial state
  puts "OMGHAI!"
  puts "-------- day 0 --------"
  puts "name, sellIn, quality"
  items.each(&print_lambda) # Assumes GildedRose::Item has a useful #to_s or uses default.

  # Simulate days
  (1..days_to_simulate).each do |day|
    puts "\n-------- day #{day} --------"
    puts "name, sellIn, quality"
    gilded_rose_app.update_quality # Perform the daily update
    items.each(&print_lambda)
  end
end

# Parse command-line arguments
# ARGV[0] will be the first argument, e.g., '5' for 5 days.
days = ARGV[0].to_i
days = 1 if days <= 0 # Default to 1 day if no valid number is provided

# Run the simulation
run_simulation(days)
